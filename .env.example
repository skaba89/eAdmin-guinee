# =============================================================================
# eAdministration Suite Guinea — Root Environment Variables
# ⚠️ NEVER commit real secrets to Git!
# Copy this file to .env and fill in your values.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
POSTGRES_DB=eadmin
POSTGRES_USER=eadmin

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# --- JWT / App Secret ---
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=CHANGE_ME_GENERATE_WITH_command_above

# --- MinIO Object Storage ---
MINIO_ROOT_USER=eadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
GRAFANA_ROOT_URL=https://monitoring.eadmin.gouv.gn

# --- Environment ---
ENVIRONMENT=development

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=eAdministration Suite Guinea

# --- Frontend Encryption Key (for client-side AES-256-GCM) ---
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'
NEXT_PUBLIC_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_command_above

# =============================================================================
# DOCKER COMPOSE USAGE
# =============================================================================
# Development: docker compose -f docker-compose.yml -f docker-compose.dev.yml up
# Production:  docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# All secrets are passed via environment variables — no hardcoded values.
# Production compose uses ${VAR:?required} to fail fast if a secret is missing.
# =============================================================================
