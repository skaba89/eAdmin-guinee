# ═══════════════════════════════════════════════════════════════
# eAdmin Guinée — Frontend Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# --- API ---
# Backend API URL (FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Database ---
# PostgreSQL connection (used by backend only, listed here for reference)
# Le frontend n'utilise plus Prisma/SQLite — toutes les données viennent de l'API FastAPI
DATABASE_URL=postgresql://eadmin:CHANGE_ME@localhost:5432/eadmin

# --- Application ---
NEXT_PUBLIC_APP_NAME=eAdministration Suite Guinea
