# eAdmin Guinée — Environment Configuration Template
# Copy this file to .env and fill in your values
# ⚠️ NEVER commit .env with real secrets
# ═══════════════════════════════════════════════════════════════════

# --- API ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=eAdministration Suite Guinea

# --- Database ---
DATABASE_URL=postgresql://eadmin:CHANGE_ME_STRONG_PASSWORD@localhost:5432/eadmin

# --- Secrets (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))") ---
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_SECRET_KEY
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
