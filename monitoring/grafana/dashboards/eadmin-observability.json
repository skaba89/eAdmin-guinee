  "id": null,
  "links": [],
  "panels": [
    {
      "title": "📊 Vue d'ensemble eAdmin Guinée",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "title": "Requêtes/seconde",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(eadmin_requests_total[5m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Latence P50/P95/P99",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(eadmin_request_duration_seconds_bucket[5m]))", "legendFormat": "P50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, rate(eadmin_request_duration_seconds_bucket[5m]))", "legendFormat": "P95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, rate(eadmin_request_duration_seconds_bucket[5m]))", "legendFormat": "P99", "refId": "C"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "s"
        }
      }
    },
    {
      "title": "Sessions actives",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "eadmin_active_sessions", "legendFormat": "Sessions", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 100}]}
        }
      }
    },
    {
      "title": "Taux d'erreur",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(eadmin_requests_total{status=~\"5..\"}[5m])) / sum(rate(eadmin_requests_total[5m])) * 100",
          "legendFormat": "Taux d'erreur 5xx",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}
        }
      }
    },
    {
      "title": "🔐 Authentification",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "collapsed": false
    },
    {
      "title": "Tentatives d'authentification",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(eadmin_auth_attempts_total{result=\"success\"}[5m])", "legendFormat": "Succès", "refId": "A"},
        {"expr": "rate(eadmin_auth_attempts_total{result=\"failure\"}[5m])", "legendFormat": "Échec", "refId": "B"}
      ]
    },
