# ═══════════════════════════════════════════════════════════════════
# eAdmin Guinée — Backend Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# --- Environment ---
ENVIRONMENT=development

# --- Database ---
DATABASE_URL=postgresql+asyncpg://eadmin:CHANGE_ME@localhost:5432/eadmin

# --- Security / JWT ---
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- MFA ---
MFA_ISSUER=eAdmin Guinée

# --- Rate Limiting ---
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300

# --- CORS ---
EXTRA_CORS_ORIGINS=[]

# --- Redis ---
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# --- MinIO / S3 ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=eadmin
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET_NAME=eadmin-documents
MINIO_SECURE=false

# --- Application ---
APP_NAME=eAdministration Suite Guinea
APP_VERSION=1.0.0
DEBUG=true
