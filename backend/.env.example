# ═══════════════════════════════════════════════════════════════
# eAdmin Guinée — Backend Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control
# ═══════════════════════════════════════════════════════════════

# --- Environment ---
# development | staging | production
ENVIRONMENT=development

# --- Database ---
DATABASE_URL=postgresql+asyncpg://eadmin:CHANGE_ME@localhost:5432/eadmin

# --- Security / JWT ---
# IMPORTANT: Generate a unique secret key for production!
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# JSON array of additional allowed origins (development only)
EXTRA_CORS_ORIGINS=[]

# --- Object Storage (MinIO / S3) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET_NAME=eadmin-documents
MINIO_SECURE=false

# --- Cache (Redis) ---
REDIS_URL=redis://localhost:6379

# --- Application ---
APP_NAME=eAdministration Suite Guinea
APP_VERSION=1.0.0
DEBUG=true

# --- Rate Limiting ---
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_API_PER_MINUTE=60
