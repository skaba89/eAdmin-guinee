# =============================================================================
# eAdministration Suite Guinea — Backend Configuration
# ⚠️ NEVER commit real secrets to Git!
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Environment ---
# Options: development, staging, production
ENVIRONMENT=development

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://user:password@host:port/database
# Generate a strong password: python -c 'import secrets; print(secrets.token_urlsafe(24))'
DATABASE_URL=postgresql+asyncpg://eadmin:CHANGE_ME_STRONG_PASSWORD@localhost:5432/eadmin

# --- Security / JWT ---
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=CHANGE_ME_GENERATE_WITH_command_above
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption Key (AES-256-GCM for sensitive data at rest) ---
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_command_above

# --- MFA ---
MFA_ISSUER=eAdmin Guinée

# --- Rate Limiting ---
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_API_PER_MINUTE=60
RATE_LIMIT_REGISTER_MAX_ATTEMPTS=3
RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600

# --- CORS ---
# JSON array of additional allowed origins (development only)
EXTRA_CORS_ORIGINS=[]

# --- Object Storage (MinIO / S3) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_BUCKET_NAME=eadmin-documents
MINIO_SECURE=false

# --- Cache (Redis) ---
# Format: redis://:password@host:port
# Generate a strong password: python -c 'import secrets; print(secrets.token_urlsafe(24))'
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379

# --- Application ---
APP_NAME=eAdministration Suite Guinea
APP_VERSION=1.0.0
DEBUG=true

# --- Session Security ---
SESSION_MAX_CONCURRENT=3
SESSION_TIMEOUT_HOURS=8
SESSION_INACTIVITY_TIMEOUT_MINUTES=30

# --- Upload Security ---
UPLOAD_MAX_SIZE_MB=50
UPLOAD_ALLOWED_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png,image/webp
UPLOAD_ANTIVIRUS_ENABLED=false
UPLOAD_QUARANTINE_PATH=/tmp/eadmin-quarantine

# --- Multi-tenant ---
TENANT_DEFAULT_ID=republique-de-guinee
TENANT_ISOLATION_MODE=strict

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
# 1. Generate UNIQUE, STRONG values for ALL CHANGE_ME fields above
# 2. Set ENVIRONMENT=production
# 3. Set DEBUG=false
# 4. Set MINIO_SECURE=true
# 5. Set UPLOAD_ANTIVIRUS_ENABLED=true
# 6. Use a secrets manager (Vault, AWS Secrets Manager, etc.)
# 7. Restrict file permissions: chmod 600 .env
# 8. NEVER commit .env to Git — .gitignore already excludes it
# =============================================================================
